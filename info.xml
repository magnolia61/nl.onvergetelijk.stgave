<?xml version="1.0"?>
<extension key="nl.onvergetelijk.stgave" type="module">
  <file>stgave</file>
  <name>Onvergetelijk - Stgave</name>
  <description>Beheert de St.Gave-regeling voor deelnemers</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Richard van Oosterhout</author>
    <email>webteam@onvergetelijk.nl</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://www.onvergetelijk.nl</url>
    <url desc="Documentation">https://www.onvergetelijk.nl</url>
    <url desc="Support">https://www.onvergetelijk.nl</url>
    <url desc="Licensing">https://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-05-05</releaseDate>
  <version>1.0.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.13</ver>
  </compatibility>
  <comments>Onderdeel van de Onvergetelijk-extensie-suite voor Stichting Onvergetelijke Zomerkampen. Compatibel met CiviCRM 6.13, PHP 8.4 en Smarty 5.</comments>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/Stgave</namespace>
    <format>25.01.1</format>
    <angularModule>crmStgave</angularModule>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
</extension>
